generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     Int                       @id @default(autoincrement())
  email                  String                    @unique
  name                   String?
  username               String?                   @unique
  passwordHash           String?
  otpCodeHash            String?
  otpExpiresAt           DateTime?
  otpRequestedAt         DateTime?
  avatarUrl              String?
  createdAt              DateTime                  @default(now())
  isVerified             Boolean                   @default(false)
  phone                  String?                   @unique
  rating                 Decimal                   @default(0) @db.Decimal(3, 2)
  reviewCount            Int                       @default(0)
  updatedAt              DateTime                  @default(now()) @updatedAt
  verificationStatus     VerificationStatus        @default(UNVERIFIED)
  googleSignInDisabledAt DateTime?
  sessionRevokedAt       DateTime?
  role                   UserRole                  @default(USER)
  addresses              Address[]
  bookings               Booking[]                 @relation("RenterBookings")
  conversationParts      ConversationParticipant[]
  googleIdentity         GoogleIdentity?
  sentMessages           Message[]                 @relation("MessageSender")
  posts                  Post[]
  reports                Report[]
  reviewsReceived        Review[]                  @relation("RevieweeReviews")
  reviewsWritten         Review[]                  @relation("ReviewerReviews")
  riscEvents             RiscEvent[]
  wishlistItems          WishlistItem[]
}

model GoogleIdentity {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  provider  String   @default("google")
  subject   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([provider, subject])
}

model RiscEvent {
  id          Int       @id @default(autoincrement())
  jti         String    @unique
  issuer      String
  audience    String
  subject     String?
  eventTypes  String[]
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id])

  @@index([subject])
  @@index([receivedAt])
}

model Address {
  id        Int      @id @default(autoincrement())
  state     String
  city      String
  pincode   String
  userId    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  country   String   @default("IN")
  label     String?
  landmark  String?
  latitude  Decimal? @db.Decimal(10, 7)
  line1     String
  line2     String?
  longitude Decimal? @db.Decimal(10, 7)
  user      User?    @relation(fields: [userId], references: [id])
  posts     Post[]

  @@index([userId])
  @@index([city, state])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  icon      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Post {
  id                   Int            @id @default(autoincrement())
  title                String
  authorId             Int
  createdAt            DateTime       @default(now())
  featured             Boolean        @default(false)
  listingType          ListingType
  updatedAt            DateTime       @updatedAt
  addressId            Int?
  categoryId           Int?
  currency             String         @default("INR")
  description          String?
  favoriteCount        Int            @default(0)
  publishedAt          DateTime?
  rentDailyPaise       Int?
  rentHourlyPaise      Int?
  rentMonthlyPaise     Int?
  rentWeeklyPaise      Int?
  securityDepositPaise Int?
  sellPricePaise       Int?
  status               PostStatus     @default(DRAFT)
  viewCount            Int            @default(0)
  videoDurationSeconds Int?
  videoMimeType        String?
  videoSizeBytes       Int?
  videoStorageKey      String?        @unique
  videoUrl             String?
  bookings             Booking[]
  conversations        Conversation[]
  images               Image[]
  address              Address?       @relation(fields: [addressId], references: [id])
  author               User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category             Category?      @relation(fields: [categoryId], references: [id])
  reviews              Review[]
  wishlistItems        WishlistItem[]

  @@index([authorId, createdAt])
  @@index([listingType, status, createdAt])
  @@index([categoryId, status, createdAt])
  @@index([status, createdAt])
}

model Image {
  id         Int      @id @default(autoincrement())
  postId     Int
  url        String
  provider   String?
  storageKey String?  @unique
  width      Int?
  height     Int?
  alt        String?
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, sortOrder])
  @@index([postId, isPrimary])
}

model Review {
  id         Int      @id @default(autoincrement())
  postId     Int
  reviewerId Int
  revieweeId Int
  rating     Decimal  @db.Decimal(2, 1)
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  reviewee   User     @relation("RevieweeReviews", fields: [revieweeId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([postId, reviewerId])
  @@index([revieweeId, createdAt])
  @@index([postId, createdAt])
}

model Conversation {
  id            Int                       @id @default(autoincrement())
  type          ConversationType          @default(DIRECT)
  postId        Int?
  lastMessageAt DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  post          Post?                     @relation(fields: [postId], references: [id])
  participants  ConversationParticipant[]
  messages      Message[]

  @@index([postId, lastMessageAt])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  conversationId Int
  userId         Int
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  isMuted        Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, lastReadAt])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  senderId       Int
  type           MessageType  @default(TEXT)
  content        String
  imageUrl       String?
  createdAt      DateTime     @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model Booking {
  id              Int           @id @default(autoincrement())
  postId          Int
  renterId        Int
  unit            RentUnit
  startAt         DateTime
  endAt           DateTime
  status          BookingStatus @default(PENDING)
  unitPricePaise  Int
  totalUnits      Int
  subtotalPaise   Int
  serviceFeePaise Int           @default(0)
  totalPricePaise Int
  currency        String        @default("INR")
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  completedAt     DateTime?
  post            Post          @relation(fields: [postId], references: [id])
  renter          User          @relation("RenterBookings", fields: [renterId], references: [id], onDelete: Cascade)

  @@index([postId, status, startAt])
  @@index([renterId, status, createdAt])
  @@index([status, startAt])
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model Report {
  id         Int      @id @default(autoincrement())
  reporterId Int
  targetType String   @db.VarChar(16)
  targetId   Int
  reason     String   @db.VarChar(120)
  details    String?
  status     String   @default("OPEN") @db.VarChar(20)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, targetType, targetId], map: "Report_unique_reporter_target_idx")
  @@index([targetType, targetId], map: "Report_target_idx")
  @@index([createdAt])
}

enum ListingType {
  SELL
  RENT
  BOTH
}

enum PostStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SOLD
  RENTED
  ARCHIVED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ConversationType {
  DIRECT
  LISTING
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum UserRole {
  USER
  ADMIN
}

enum RentUnit {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
  EXPIRED
}
